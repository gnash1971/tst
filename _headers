# En-tête de sécurité faisant autorité (prioritaire sur la balise <meta>).
# Choix assumé : style-src conserve 'unsafe-inline' car les pages autonomes
# (404.html, fic/*.html, pub/flyerA5.html) embarquent leurs styles dans des
# blocs <style>. Risque faible et accepté : aucune balise <script> inline n'est
# autorisée (script-src 'self') et le HTML ne contient aucun attribut style="".
# Hacher chaque bloc <style> serait fragile à maintenir pour un gain marginal.
/*
  Content-Security-Policy: default-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'; object-src 'none'; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self'; img-src 'self' data:; connect-src 'self';
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Le service worker doit être revalidé à chaque visite pour propager
# rapidement une nouvelle version (évite un SW « collé » sur l'ancien cache).
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Cache long pour les ressources stables non fingerprintées les plus lourdes.
# (css/js volontairement laissés sur la revalidation ETag par défaut de Netlify
# car leurs noms de fichiers ne changent pas à chaque évolution du site.)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/logo/*
  Cache-Control: public, max-age=86400

/pub/*
  Cache-Control: public, max-age=86400
