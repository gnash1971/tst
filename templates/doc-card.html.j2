                <div id="{{ id }}" class="doc-card bg-white dark:bg-slate-900 rounded-2xl border border-slate-200/80 dark:border-slate-800 shadow-sm hover:shadow-lg hover:border-{{ accent }}-500/40 dark:hover:border-{{ accent }}-400/40 transition-all duration-300 flex flex-col overflow-hidden group" data-category="{{ category }}" data-search="{{ search }}">
                    <div class="h-1 bg-{{ accent }}-600 dark:bg-{{ accent }}-500"></div>
                    <div class="p-8 flex-grow flex flex-col justify-between">
                        <div>
                            <div class="flex items-start justify-between mb-6">
                                <div class="p-4 bg-{{ icon_color }}-50 dark:bg-{{ icon_color }}-950/40 text-{{ icon_color }}-600 dark:text-{{ icon_color }}-400 rounded-2xl group-hover:scale-105 transition-transform duration-300">
                                    <i data-lucide="{{ icon }}" class="h-7 w-7"></i>
                                </div>
                                <div class="flex flex-col items-end space-y-1">
                                    <span class="px-2.5 py-1 rounded-full text-xs font-bold uppercase tracking-wider bg-{{ badge_color }}-100 dark:bg-{{ badge_color }}-950/80 text-{{ badge_color }}-800 dark:text-{{ badge_color }}-300 border border-{{ badge_color }}-200/50 dark:border-{{ badge_color }}-900/50">
                                        {{ badge_label }}
                                    </span>
                                    <span class="text-[10px] text-slate-500 dark:text-slate-400 font-semibold uppercase tracking-wider">
                                        {{ version_label }}
                                    </span>
                                </div>
                            </div>

                            <h3 class="text-2xl font-bold text-slate-900 dark:text-white group-hover:text-{{ accent }}-600 dark:group-hover:text-{{ accent }}-400 transition-colors duration-200 mb-3">
                                {{ title }}
                            </h3>

{% if media and media.type == 'image' %}
                            <a href="{{ media.src }}" target="_blank" rel="noopener noreferrer" class="block mb-6 rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white overflow-hidden" aria-label="{{ media.aria_label }}">
{% if media.srcset_webp %}
                                <picture class="contents">
                                    <source type="image/avif" srcset="{{ media.srcset_avif }}"{% if media.sizes %} sizes="{{ media.sizes }}"{% endif %}>
                                    <source type="image/webp" srcset="{{ media.srcset_webp }}"{% if media.sizes %} sizes="{{ media.sizes }}"{% endif %}>
                                    <img src="{{ media.src }}" alt="{{ media.alt }}" data-logo-fallback="hide" loading="lazy" decoding="async" class="w-full h-auto group-hover:scale-[1.02] transition-transform duration-300">
                                </picture>
{% else %}
                                <img src="{{ media.src }}" alt="{{ media.alt }}" data-logo-fallback="hide" loading="lazy" decoding="async" class="w-full h-auto group-hover:scale-[1.02] transition-transform duration-300">
{% endif %}
                            </a>

{% elif media and media.type == 'qr' %}
                            <a href="{{ media.href }}" target="_blank" rel="noopener noreferrer" class="block mb-6 rounded-xl border border-{{ accent }}-200/80 dark:border-{{ accent }}-800 bg-gradient-to-br from-{{ accent }}-50 to-white dark:from-{{ accent }}-950/40 dark:to-slate-900 p-4 overflow-hidden">
                                <div class="flex items-center gap-4">
                                    <div class="shrink-0 rounded-lg bg-white p-2 shadow-sm border border-slate-100 dark:border-slate-700">
                                        <img src="{{ media.qr_src }}" alt="" width="72" height="72" loading="lazy" decoding="async" class="w-16 h-16">
                                    </div>
                                    <div class="min-w-0">
                                        <p class="text-xs font-bold uppercase tracking-wider text-{{ accent }}-700 dark:text-{{ accent }}-300">{{ media.kicker }}</p>
                                        <p class="text-sm font-semibold text-slate-900 dark:text-white mt-1">{{ media.title }}</p>
                                        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">{{ media.subtitle }}</p>
                                    </div>
                                </div>
                            </a>

{% endif %}
                            <p class="texte-redactionnel text-slate-600 dark:text-slate-300 mb-6 leading-relaxed text-sm">
                                {{ description_html }}
                            </p>

                            <div class="key-content space-y-2 mb-8">
                                <h4 class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Contenu clé :</h4>
                                <ul class="grid grid-cols-2 gap-2 text-xs text-slate-600 dark:text-slate-400">
{% for point in key_points %}
                                    <li class="flex items-center space-x-2">
                                        <i data-lucide="check" class="h-3.5 w-3.5 text-{{ accent }}-600 dark:text-{{ accent }}-400 shrink-0"></i>
                                        <span>{{ point }}</span>
                                    </li>
{% endfor %}
                                </ul>
                            </div>
                        </div>

                        <div class="pt-4 border-t border-slate-100 dark:border-slate-800/60 flex items-center justify-between">
                            <span class="text-xs text-slate-500 dark:text-slate-400">{{ footer_note }}</span>
                            <a href="{{ cta_href }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center space-x-2 px-5 py-2.5 bg-{{ accent }}-700 hover:bg-{{ accent }}-800 text-white rounded-xl text-sm font-semibold shadow-md shadow-{{ accent }}-500/10 hover:shadow-lg hover:shadow-{{ accent }}-500/20 transition-all duration-200">
                                <span>{{ cta_label }}</span>
                                <i data-lucide="arrow-right" class="h-4 w-4"></i>
                            </a>
                        </div>
                    </div>
                </div>
